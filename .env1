FLASK_SECRET_KEY=change-this
PORT=5000
LOG_LEVEL=INFO

# SQL query file paths + default picklist mode (guns/components)
GUNS_QUERY_FILE=query_guns.sql
COMPONENTS_QUERY_FILE=query_components.sql
DEFAULT_QUERY_TYPE=guns
MAX_RUNS_TO_KEEP=10

# Use SQLAlchemy connection format for pyodbc
# Example:
# MSSQL_CONNECTION_STRING=mssql+pyodbc://username:password@server/database?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
# Use mssql+pymssql for local (no ODBC needed); use mssql+pyodbc in Docker (see .env.example)
MSSQL_CONNECTION_STRING=mssql+pymssql://TYLWHI:Whit123#@10.217.24.25/VECA

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_RECIPIENT=
SMTP_USE_TLS=true

# Scheduler
ENABLE_SCHEDULER=true
SCHEDULE_TIME=05:00
SCHEDULE_TIMEZONE=UTC
