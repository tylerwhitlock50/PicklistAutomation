FLASK_SECRET_KEY=change-this
PORT=5000
LOG_LEVEL=INFO
FLASK_DEBUG=false

# Dashboard: seconds between status API polls when idle (faster while a run is active)
UI_REFRESH_INTERVAL_SECONDS=5

# SQL query file paths + default picklist mode (guns/components)
GUNS_QUERY_FILE=sql/query_guns.sql
COMPONENTS_QUERY_FILE=sql/query_components.sql
DEFAULT_QUERY_TYPE=guns
MAX_RUNS_TO_KEEP=10
RUN_HISTORY_DB_PATH=data/picklist_history.db

# Shipping ops (all optional — sensible defaults)
# RECON_SHIPMENTS_FILE=sql/recon_shipments.sql
# PICK_SERIAL_LOOKUP_FILE=sql/pick_serial_lookup.sql
# Days of daily picklist plan snapshots kept for end-of-day reconciliation
# PLAN_SNAPSHOT_RETENTION_DAYS=60
# Staged shipments should leave within this many hours
# STAGE_AGING_TARGET_HOURS=48
# SHIPPING locations containing this term count as stage bins
# STAGE_LOCATION_TERM=STAGE
# Component shortage report: horizon, product codes in scope, ERP cache
# SHORTAGE_QUERY_FILE=sql/shortage_components.sql
# SHORTAGE_LOOKAHEAD_DAYS=10
# SHORTAGE_PRODUCT_CODES=FG-COMP,FG-STOCK,FG-APPAREL,COMPONENT,FG-BASE,FG-RING,FG-BARREL,FG-MUZZLE
# SHORTAGE_CACHE_MINUTES=5

# Use SQLAlchemy connection format for pyodbc
# Example:
# MSSQL_CONNECTION_STRING=mssql+pyodbc://username:password@server/database?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
MSSQL_CONNECTION_STRING=

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# SMTP
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_SENDER=
SMTP_RECIPIENT=
SMTP_USE_TLS=true

# Scheduler
ENABLE_SCHEDULER=true
SCHEDULE_TIME=05:00
# Example for Mountain local time (DST-aware): America/Denver
# Example for fixed MST year-round (UTC-7): Etc/GMT+7
SCHEDULE_TIMEZONE=UTC

# Access control for factory/local network use:
# - private: allow private/loopback clients (default)
# - cidr: allow only ACCESS_ALLOWED_CIDRS
# - off: disable checks
ACCESS_MODE=private
ACCESS_ALLOWED_CIDRS=
TRUST_PROXY_HEADERS=false

# Settings page unlock password (simple gate for /settings UI)
SETTINGS_PASSWORD=InforSystem

# Optional: encrypt sensitive settings stored in SQLite
# Generate with:
# python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SETTINGS_ENCRYPTION_KEY=

# PG login 
DATABASE_URL = 